# ─── Supabase ───────────────────────────────────────────
# Obtén estos valores en: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Super-admin del panel /admin: se gestiona vía Supabase Auth
# (email/password). Crear el user desde Dashboard → Authentication → Users.
# El UUID autorizado se fija en la migración 013_super_admin.sql

# ─── Web Push (VAPID) ───────────────────────────────────
# Generar par con: npx web-push generate-vapid-keys
# - La pública se expone al cliente (PushManager.subscribe)
# - La privada solo se configura como secret en Supabase Edge Functions
NEXT_PUBLIC_VAPID_PUBLIC_KEY=tu-vapid-public-key

# Secrets que deben configurarse en Supabase Dashboard
# (Edge Functions → Manage secrets). NO los pongas en .env.local:
#   VAPID_PUBLIC_KEY  (mismo valor que NEXT_PUBLIC_VAPID_PUBLIC_KEY)
#   VAPID_PRIVATE_KEY
#   VAPID_SUBJECT     (e.g. mailto:admin@tudominio.com)
